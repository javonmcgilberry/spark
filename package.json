{
  "name": "spark",
  "version": "0.1.0",
  "private": true,
  "description": "AI onboarding companion for new Webflow engineers.",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
