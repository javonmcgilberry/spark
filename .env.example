# =============================================================================
# Spark environment
# =============================================================================
# Copy to .env. Wrangler reads this file via the .dev.vars symlink; Next.js
# dev reads it directly. Webflow Cloud takes these same vars from the project
# environment settings — not from a file.
#
# Zero-token local dev: set the two MOCK_MODE flags below and you can boot
# `npm run dev` with the rest of this file empty.

# -----------------------------------------------------------------------------
# Slack
# -----------------------------------------------------------------------------
# Required when SLACK_MOCK_MODE is off. Get both from api.slack.com/apps →
# your app → "OAuth & Permissions" / "Basic Information".
SLACK_BOT_TOKEN=xoxb-
SLACK_SIGNING_SECRET=

# -----------------------------------------------------------------------------
# Anthropic
# -----------------------------------------------------------------------------
# Required when ANTHROPIC_MOCK_MODE is off.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# -----------------------------------------------------------------------------
# Mock modes — local dev only
# -----------------------------------------------------------------------------
# "1" or "true" to replace the real client with a recording stub. Webflow
# Cloud should leave these unset. See lib/ctx.ts for the flip points.
SLACK_MOCK_MODE=
ANTHROPIC_MOCK_MODE=

# -----------------------------------------------------------------------------
# Integrations — all optional, each service no-ops if its vars are unset
# -----------------------------------------------------------------------------

# GitHub — used to read CODEOWNERS and public contribution signal for
# people insights. GITHUB_ORG and GITHUB_CODEOWNERS_REPO default to
# "webflow" and "webflow/webflow" respectively.
GITHUB_TOKEN=
GITHUB_ORG=
GITHUB_CODEOWNERS_REPO=

# Jira — used for people insights (recent tickets, active epics).
# Both required together or Jira is skipped. Basic auth email comes
# from the Cloudflare Access JWT (Okta SSO) at request time — there is
# no JIRA_API_EMAIL. For local dev without CF Access, Jira is skipped.
JIRA_BASE_URL=https://webflow.atlassian.net
JIRA_API_TOKEN=

# Confluence — used to resolve team homes, pillar homes, and personal
# user guides. Both required together or Confluence is skipped. Basic
# auth email also comes from the CF Access JWT.
CONFLUENCE_BASE_URL=https://webflow.atlassian.net/wiki
CONFLUENCE_API_TOKEN=

# -----------------------------------------------------------------------------
# Session (local dev only)
# -----------------------------------------------------------------------------
# On Webflow Inside, the acting manager is identified automatically from
# the Cloudflare Access JWT that Okta SSO attaches to every request — no
# env var needed. Spark resolves the JWT email to a Slack user via
# users.lookupByEmail.
#
# This fallback is only read when no CF Access identity is present — i.e.
# running `npm run dev` locally or `npm run preview` without a proxy in
# front. Must start with "U".
DEMO_MANAGER_SLACK_ID=

# -----------------------------------------------------------------------------
# D1 (draft persistence)
# -----------------------------------------------------------------------------
# Nothing here — D1 is a Workers binding declared in wrangler.jsonc, not an
# env var. Webflow Cloud provisions the database automatically on each
# deploy and applies everything under migrations/. See wrangler.jsonc for
# why the placeholder database_id is intentional.
#
# For the local Worker preview (`npm run preview`) the `setup` script creates
# a local SQLite copy at .wrangler/state/v3/d1/. `npm run dev` doesn't need
# D1 at all — it falls back to an in-memory store.
# -----------------------------------------------------------------------------
