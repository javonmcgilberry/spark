# Server
PORT=8787

# Slack app credentials (Socket Mode)
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...

# LLM
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# GitHub (used only for fetching CODEOWNERS and team metadata — no write access needed)
GITHUB_TOKEN=

# Statsig Console API (for stale flag scanning)
STATSIG_CONSOLE_SDK_KEY=

# DX data warehouse (for team lookup)
DX_WAREHOUSE_DSN=

# Confluence (for onboarding docs)
CONFLUENCE_API_TOKEN=
CONFLUENCE_BASE_URL=https://webflow.atlassian.net/wiki

# Path to the Webflow monorepo (read-only, for codebase scanning)
WEBFLOW_MONOREPO_PATH=../

# Manager Dashboard API (Webflow Cloud frontend)
# Bearer token the UI presents on every /api/* request. Generate with: openssl rand -hex 32
SPARK_API_TOKEN=

# -----------------------------------------------------------------------------
# Manager Dashboard web app (spark/web)
# Consumed via a symlink: spark/web/.env.local -> ../.env
# Also read by Wrangler for OpenNext preview via: spark/web/.dev.vars -> ../.env
# -----------------------------------------------------------------------------

# Base URL of the bot HTTP API from the web app's perspective.
#   Local dev:     http://localhost:8787
#   Webflow Cloud: https://<handle>.trycloudflare.com (printed by scripts/tunnel.sh)
SPARK_API_BASE_URL=http://localhost:8787

# Demo-mode fallback for the acting manager's Slack id (must start with U).
# Replace with Slack OAuth post-hackathon.
DEMO_MANAGER_SLACK_ID=
