# Server
PORT=8787

# Slack app credentials (Socket Mode)
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...

# LLM
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# GitHub (used only for fetching CODEOWNERS and team metadata — no write access needed)
GITHUB_TOKEN=

# Statsig Console API (for stale flag scanning)
STATSIG_CONSOLE_SDK_KEY=

# DX data warehouse (for team lookup)
DX_WAREHOUSE_DSN=

# Confluence (for onboarding docs)
CONFLUENCE_API_TOKEN=
CONFLUENCE_BASE_URL=https://webflow.atlassian.net/wiki

# Path to the Webflow monorepo (read-only, for codebase scanning)
WEBFLOW_MONOREPO_PATH=../
