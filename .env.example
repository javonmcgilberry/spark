# =============================================================================
# Environment Variables Template
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file. It is already in .gitignore.
#

# -----------------------------------------------------------------------------
# LLM Providers (set spending limits on each account!)
# -----------------------------------------------------------------------------

# OpenAI — https://platform.openai.com/api-keys
# Set usage limits: https://platform.openai.com/account/limits
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic — https://console.anthropic.com/settings/keys
# Set spending limit: https://console.anthropic.com/settings/plans
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google AI (Gemini) — https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------

# Generate a random string: openssl rand -hex 32
JWT_SECRET=generate-a-random-string-here

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

PORT=3000
NODE_ENV=development
